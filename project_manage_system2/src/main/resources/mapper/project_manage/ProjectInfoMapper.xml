<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project_manage.mapper.ProjectInfoMapper">

    <resultMap type="com.ruoyi.project_manage.domain.ProjectInfo" id="ProjectResult">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="code" column="code"/>
        <result property="principalId" column="principal_id"/>
        <result property="principalName" column="principal_name"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="status" column="status"/>
        <result property="totalProgress" column="total_progress"/>
        <result property="description" column="description"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <sql id="selectProjectVo">
        SELECT p.id, p.name, p.code, p.principal_id, u.user_name as principal_name,
               p.start_time, p.end_time, p.status, p.total_progress, p.description,
               p.create_by, p.create_time, p.update_by, p.update_time, p.remark
        FROM project_manage_info p
        LEFT JOIN sys_user u ON p.principal_id = u.user_id AND u.del_flag = '0'
    </sql>

    <select id="selectProjectList" resultMap="ProjectResult">
        <include refid="selectProjectVo"/>
        <where>
            p.del_flag = '0'
            <if test="query.name != null and query.name != ''">
                AND p.name LIKE CONCAT('%', #{query.name}, '%')
            </if>
            <if test="query.code != null and query.code != ''">
                AND p.code LIKE CONCAT('%', #{query.code}, '%')
            </if>
            <if test="query.principalId != null">
                AND p.principal_id = #{query.principalId}
            </if>
            <if test="query.status != null">
                AND p.status = #{query.status}
            </if>
            <if test="query.startTimeBegin != null">
                AND p.start_time &gt;= #{query.startTimeBegin}
            </if>
            <if test="query.startTimeEnd != null">
                AND p.start_time &lt;= #{query.startTimeEnd}
            </if>
            <if test="query.endTimeBegin != null">
                AND p.end_time &gt;= #{query.endTimeBegin}
            </if>
            <if test="query.endTimeEnd != null">
                AND p.end_time &lt;= #{query.endTimeEnd}
            </if>
            <!-- 数据权限过滤 -->
            ${params.dataScope}
        </where>
        ORDER BY p.create_time DESC
    </select>

    <select id="selectProjectById" resultMap="ProjectResult">
        <include refid="selectProjectVo"/>
        WHERE p.id = #{id} AND p.del_flag = '0'
    </select>

    <select id="checkCodeUnique" resultMap="ProjectResult">
        <include refid="selectProjectVo"/>
        WHERE p.code = #{code} AND p.del_flag = '0' LIMIT 1
    </select>

    <update id="updateProjectProgress">
        UPDATE project_manage_info
        SET total_progress = #{progress},
            update_time = NOW()
        WHERE id = #{projectId} AND del_flag = '0'
    </update>

</mapper>
