<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project_manage.mapper.ProjectConfigMapper">

    <resultMap type="com.ruoyi.project_manage.domain.ProjectConfig" id="ProjectConfigResult">
        <id property="id" column="id"/>
        <result property="configKey" column="config_key"/>
        <result property="configValue" column="config_value"/>
        <result property="configDesc" column="config_desc"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectProjectConfigVo">
        SELECT id, config_key, config_value, config_desc,
               create_by, create_time, update_by, update_time
        FROM project_manage_config
    </sql>

    <select id="selectByConfigKey" resultMap="ProjectConfigResult">
        <include refid="selectProjectConfigVo"/>
        WHERE config_key = #{configKey} LIMIT 1
    </select>

</mapper>
